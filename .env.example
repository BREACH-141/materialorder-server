# Copy this file to .env and fill in real values before running the server.

# Required. Get this free at https://resend.com after creating an account.
RESEND_API_KEY=re_your_real_key_here 

# The address stock-check emails are sent FROM.
# Resend's shared test domain (onboarding@resend.dev) can ONLY deliver to the
# email address you signed up to Resend with — it CANNOT email real suppliers.
# To actually email suppliers, verify your own domain in the Resend dashboard
# (Domains -> Add Domain -> add the DNS records they give you), then set this
# to an address on that domain, e.g. orders@yourdomain.com
FROM_EMAIL=onboarding@resend.dev

# The public base URL this server will be reachable at once deployed.
# Used to build the reply link suppliers click in the email.
# While testing locally this can stay as localhost, but suppliers obviously
# can't reach localhost — set this to your real deployed URL before going live.
PUBLIC_BASE_URL=http://localhost:3001

# Port the server listens on.
PORT=3001
